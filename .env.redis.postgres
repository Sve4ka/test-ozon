COMPOSE_PROFILES=postgres,redis

SERVICE_HOST=0.0.0.0
SERVICE_PORT=8080
SHORT_LINK_ADDRESS=http://localhost:8080/link/

STORAGE_TYPE=postgres
CACHE_TYPE=redis
CACHE_TTL=24h
GENERATE_ATTEMPTS=10

PG_HOST=postgres
PG_PORT=5432
PG_USER=root
PG_PASSWORD=1234
PG_NAME=postgres
PG_MAX_POOL=10
PG_TIMEOUT=1s
PG_CONN_ATTEMPTS=10

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=1234